# ============================================================
# SmartBankAI Backend — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── AWS Configuration ───────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# ─── AWS Cognito ─────────────────────────────────────────────
# Get from: AWS Console → Cognito → User Pools
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── MongoDB Atlas ────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>
MONGODB_URI=mongodb+srv://smartbankai:password@cluster0.abcde.mongodb.net/smartbankai
MONGODB_DB_NAME=smartbankai

# ─── AWS SES (Email) ──────────────────────────────────────────
# Must be a verified identity in SES
SES_FROM_EMAIL=noreply@smartbankai.com
SES_FROM_NAME=SmartBankAI

# ─── AWS SNS ──────────────────────────────────────────────────
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:SmartBankAI-Notifications-prod
SNS_LOAN_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:SmartBankAI-LoanEvents-prod

# ─── AWS EventBridge ─────────────────────────────────────────
EVENT_BUS_NAME=SmartBankAI-Events-prod

# ─── AWS S3 Buckets ──────────────────────────────────────────
S3_KYC_BUCKET=smartbankai-kyc-documents-prod-123456789012
S3_LOAN_DOCS_BUCKET=smartbankai-loan-documents-prod-123456789012
S3_USER_FILES_BUCKET=smartbankai-user-files-prod-123456789012

# ─── AWS SQS ─────────────────────────────────────────────────
NOTIFICATION_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/SmartBankAI-NotificationQueue-prod
EVENTS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/SmartBankAI-EventsQueue-prod.fifo

# ─── Deployment ───────────────────────────────────────────────
CF_STACK_NAME=smartbankai-backend
S3_DEPLOYMENT_BUCKET=smartbankai-deployment-artifacts-123456789012
NODE_ENV=production
LOG_LEVEL=info
APP_NAME=SmartBankAI

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_URL=https://smartbankai.com
